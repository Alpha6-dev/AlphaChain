# AlphaChain Platform Configuration

# Fabric Network
FABRIC_LOGGING_SPEC=INFO
FABRIC_CHANNEL_NAME=alphachannel
FABRIC_CHAINCODE_NAME=alphachain-shipment

# CouchDB (state database)
COUCHDB_USER=admin
COUCHDB_PASSWORD=adminpw

# PostgreSQL (off-chain)
POSTGRES_DB=alphachain
POSTGRES_USER=alphachain
POSTGRES_PASSWORD=alphachain_secret

# API Server
API_PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-in-production
LOG_LEVEL=info
