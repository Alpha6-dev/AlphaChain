# AlphaChain API Configuration

# Server
PORT=3001
NODE_ENV=development

# Hyperledger Fabric
FABRIC_CHANNEL_NAME=alphachannel
FABRIC_CHAINCODE_NAME=alphachain-shipment
FABRIC_WALLET_PATH=./wallet
FABRIC_CONNECTION_PROFILE=./connection-profile.json
FABRIC_MSP_ID=AlphaOrgMSP
FABRIC_CA_URL=https://ca.alpha.alphachain.com:7054

# PostgreSQL (off-chain metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alphachain
POSTGRES_USER=alphachain
POSTGRES_PASSWORD=alphachain_secret

# Security
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h

# Logging
LOG_LEVEL=info
